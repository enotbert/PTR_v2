# Local LM Studio OpenAI-compatible API (ADR-0006).
# Copy to `.env.local` (gitignored) and adjust without committing.

PTR_CODER_BASE_URL=http://localhost:1234/v1
PTR_CODER_MODEL=gemma-4-26b-a4b-it

# LM Studio accepts arbitrary local bearer strings; override if your server requires it.
# PTR_CODER_API_KEY=lm-studio

# --- Docker Compose dev stack (see docs/tech/docker-dev.md) ---
# Copy this file to `.env` for overrides; demo values below are placeholders, not production secrets.

# POSTGRES_USER=ptr
# POSTGRES_PASSWORD=ptr_dev_demo
# POSTGRES_DB=ptr_dev
# Non-default host ports (avoid clashes with local Postgres / dev servers).
# POSTGRES_PUBLISH_PORT=15432
# BACKEND_PUBLISH_PORT=18080
# FRONTEND_PUBLISH_PORT=15173
