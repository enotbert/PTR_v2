# PTR v2 — production template (inject via Secrets Manager / k8s Secret / Vault; never commit real values).

# --- Application ---
# PYTHON_ENV=production
# NODE_ENV=production

# --- Database (managed Postgres; replace with your deployment host and credentials) ---
# DATABASE_URL=postgresql://USER:PASSWORD@YOUR_HOST:5432/YOUR_DATABASE

# If you orchestrate Postgres with Compose on a server, use strong passwords and restrict network exposure.
# POSTGRES_USER=
# POSTGRES_PASSWORD=
# POSTGRES_DB=

# --- Public URLs / CORS (set when APIs need them) ---
# PUBLIC_API_BASE_URL=https://api.example.com
# CORS_ALLOWED_ORIGINS=https://app.example.com

# Host port overrides only relevant if you use docker-compose publishes in production-like compose files.
# POSTGRES_PUBLISH_PORT=
# BACKEND_PUBLISH_PORT=
# FRONTEND_PUBLISH_PORT=

# --- ptr_coder / LM Studio — local agent tooling only; omit in production runtime services ---
