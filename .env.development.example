# PTR v2 — local development (copy to `.env.development`, never commit).
# Docker Compose: `docker compose --env-file .env.development up --build`
# (Compose also reads `.env` if present; prefer an explicit `--env-file` to avoid mixing with prod.)

# --- ptr_coder / LM Studio (ADR-0006) ---
PTR_CODER_BASE_URL=http://localhost:1234/v1
PTR_CODER_MODEL=gemma-4-26b-a4b-it
# LM Studio accepts arbitrary local bearer strings; set if required.
# PTR_CODER_API_KEY=lm-studio

# --- Docker Compose dev stack (see docs/tech/docker-dev.md) ---
# Demo placeholders only — not production secrets.

POSTGRES_USER=ptr
POSTGRES_PASSWORD=ptr_dev_demo
POSTGRES_DB=ptr_dev

# Host publish ports (defaults match docker-compose.yml non-standard mappings).
# POSTGRES_PUBLISH_PORT=15432
# BACKEND_PUBLISH_PORT=18080
# FRONTEND_PUBLISH_PORT=15173
