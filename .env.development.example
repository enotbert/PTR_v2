# PTR v2 — local development (copy to `.env.development`, never commit).
# Docker Compose: `docker compose --env-file .env.development up --build`
# (Compose also reads `.env` if present; prefer an explicit `--env-file` to avoid mixing with prod.)

# --- ptr_coder / LM Studio (ADR-0006) ---
PTR_CODER_BASE_URL=http://localhost:1234/v1
PTR_CODER_MODEL=qwen3-coder-30b-a3b-instruct
# LM Studio accepts arbitrary local bearer strings; set if required.
# PTR_CODER_API_KEY=lm-studio

# --- Docker Compose dev stack (see docs/tech/docker-dev.md) ---
# Demo placeholders only — not production secrets.

POSTGRES_USER=ptr
POSTGRES_PASSWORD=ptr_dev_demo
POSTGRES_DB=ptr_dev

# Backend DATABASE_URL is set inside docker-compose.yml from the values above (host `postgres`, port 5432 in the Compose network).
# Use the line below only when running the FastAPI app on the host (not in the backend container): point at the published Postgres port.
# DATABASE_URL=postgresql://ptr:ptr_dev_demo@127.0.0.1:15432/ptr_dev

# Host publish ports (defaults match docker-compose.yml non-standard mappings).
# POSTGRES_PUBLISH_PORT=15432
# BACKEND_PUBLISH_PORT=18080
# FRONTEND_PUBLISH_PORT=15173

# Browser-visible backend URL for the Vite app (not the internal Docker hostname).
# Must match how you reach FastAPI from the host (see BACKEND_PUBLISH_PORT, default 18080).
# VITE_API_BASE_URL=http://localhost:18080

# CORS for browser requests from frontend dev servers to backend.
# Comma-separated origins, no spaces.
# CORS_ALLOW_ORIGINS=http://localhost:15173,http://127.0.0.1:15173,http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
