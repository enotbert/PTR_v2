  "components": {
    "schemas": {
      "AddTavernContributionBody": {
        "properties": {
          "amount": {
            "type": "integer",
            "maximum": 10000.0,
            "exclusiveMinimum": 0.0,
            "title": "Amount"
          },
          "source_type": {
            "type": "string",
            "enum": [
              "raid_reward",
              "weekly_event",
              "manual_spend"
            ],
            "title": "Source Type",
            "default": "raid_reward"
          },
          "source_ref": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 128
              },
              {
                "type": "null"
              }
            ],
            "title": "Source Ref"
          }
        },
        "type": "object",
        "required": [
          "amount"
        ],
        "title": "AddTavernContributionBody"
      },
      "AnalyticsDebugEventListOut": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/AnalyticsDebugEventOut"
            },
            "type": "array",
            "title": "Items"
          }
        },
        "type": "object",
        "title": "AnalyticsDebugEventListOut"
      },
      "AnalyticsDebugEventOut": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "event_name": {
            "type": "string",
            "title": "Event Name"
          },
          "player_id": {
            "anyOf": [
              {
                "type": "string",
                "format": "uuid"
              },
              {
                "type": "null"
              }
            ],
            "title": "Player Id"
          },
          "session_id": {
            "anyOf": [
              {
                "type": "string",
                "format": "uuid"
              },
              {
                "type": "null"
              }
            ],
            "title": "Session Id"
          },
          "raid_id": {
            "anyOf": [
              {
                "type": "string",
                "format": "uuid"
              },
              {
                "type": "null"
              }
            ],
            "title": "Raid Id"
          },
          "battle_id": {
            "anyOf": [
              {
                "type": "string",
                "format": "uuid"
              },
              {
                "type": "null"
              }
            ],
            "title": "Battle Id"
          },
          "event_at": {
            "type": "string",
            "format": "date-time",
            "title": "Event At"
          }
        },
        "type": "object",
        "required": [
          "id",
          "event_name",
          "event_at"
        ],
        "title": "AnalyticsDebugEventOut"
      },
      "CreateSessionBody": {
        "properties": {
          "display_name": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 64
              },
              {
                "type": "null"
              }
