# Normalize line endings cross-platform.
# - Auto-detect text files; checkout with native endings on Windows by default.
# - Force LF on shell scripts and other formats that REQUIRE LF on Linux/macOS,
#   regardless of contributor's OS or core.autocrlf setting.

* text=auto

# Force LF on these (CRLF would break execution / parsing on POSIX runners).
*.sh        text eol=lf
*.bash      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
Dockerfile  text eol=lf
Makefile    text eol=lf

# Markdown stays as-is (rendering tolerates either).
*.md        text

# Binary formats — never normalize.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.gz        binary
